# Configuración del sistema Alsua Transport

# MySQL
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=alsua_transport

# CRM GM Transport
CRM_URL=https://softwareparatransporte.com
CRM_USER=
CRM_PASSWORD=

# Sistema
LIMITE_VIAJES_POR_CICLO=3
TIEMPO_ESPERA_EXITOSO=60
TIEMPO_ESPERA_FALLIDO=30
TIEMPO_ESPERA_LOGIN_LIMIT=900

# Circuit Breaker
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_MAX_SAME_ERROR=10
CIRCUIT_BREAKER_MAX_ERROR_RATE=0.90

# Reprocesamiento
FAILED_TRIPS_DIR=data/failed_trips
AUTO_SAVE_FAILED_TRIPS=true

# Logging
LOG_LEVEL=INFO
LOG_JSON_ENABLED=false
LOG_DIR=data/logs
